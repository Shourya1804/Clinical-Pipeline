# Copy this file to ".env" (or set the variable in your shell) to enable SNOMED
# linking via the UMLS API. Get a free key at https://uts.nlm.nih.gov/uts/signup-login
# then find it under UTS profile -> "My Profile" -> API Key.
#
# RxNorm linking (medications) needs NO key and works without this.

UMLS_API_KEY=your-umls-api-key-here
